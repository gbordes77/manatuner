{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$metadata": {
    "name": "ManaTuner Design System",
    "edition": "2.6",
    "surface": "light",
    "darkTheme": "intentionally excluded — see BRANDBOOK.md §10"
  },

  "color": {
    "mana": {
      "white": {
        "value": "#F8F6D8",
        "type": "color",
        "description": "Plains — warm cream. Info-light, accents."
      },
      "blue": {
        "value": "#0E68AB",
        "type": "color",
        "description": "Island — deep blue. Primary brand. Knowledge CTA. Info."
      },
      "black": {
        "value": "#150B00",
        "type": "color",
        "description": "Swamp — near-black. Body ink on parchment ground only."
      },
      "red": {
        "value": "#D3202A",
        "type": "color",
        "description": "Mountain — vivid red. Error, destructive, attention."
      },
      "green": {
        "value": "#00733E",
        "type": "color",
        "description": "Forest — forest green. Success, validated state."
      },
      "colorless": {
        "value": "#CBC5C0",
        "type": "color",
        "description": "Wastes — neutral grey. Disabled state."
      },
      "multicolor": {
        "value": "#E9B54C",
        "type": "color",
        "description": "Gold — premium. Reserved for the single primary CTA per page."
      }
    },

    "brand": {
      "primary": {
        "value": "#1565C0",
        "type": "color",
        "description": "Solid brand blue — Tier 3 default buttons."
      },
      "primaryDeep": {
        "value": "#0D47A1",
        "type": "color",
        "description": "Hover state for brand.primary."
      }
    },

    "surface": {
      "background": {
        "value": "#F5F3EE",
        "type": "color",
        "description": "Parchment ground — base of every page."
      },
      "backgroundDeep": {
        "value": "#EDE9E0",
        "type": "color",
        "description": "Inset wells, token-line backgrounds."
      },
      "paper": {
        "value": "#FFFFFF",
        "type": "color",
        "description": "Card surface, raised content."
      }
    },

    "ink": {
      "primary": { "value": "#1A1A1A", "type": "color", "description": "Body text." },
      "secondary": {
        "value": "#555555",
        "type": "color",
        "description": "Secondary text, descriptions."
      },
      "tertiary": {
        "value": "#9A958C",
        "type": "color",
        "description": "Captions, mono labels, low-emphasis."
      }
    },

    "rule": {
      "default": {
        "value": "rgba(26, 26, 26, 0.08)",
        "type": "color",
        "description": "Hairline rules, card borders."
      },
      "soft": {
        "value": "rgba(26, 26, 26, 0.04)",
        "type": "color",
        "description": "Within-card dividers."
      }
    },

    "state": {
      "error": { "value": "{color.mana.red}", "type": "color" },
      "warning": { "value": "{color.mana.multicolor}", "type": "color" },
      "info": { "value": "{color.mana.blue}", "type": "color" },
      "success": { "value": "{color.mana.green}", "type": "color" },
      "disabled": { "value": "{color.mana.colorless}", "type": "color" }
    }
  },

  "gradient": {
    "ctaPremium": {
      "value": "linear-gradient(135deg, #E9B54C 0%, #FFD700 100%)",
      "type": "gradient",
      "description": "Tier 1 — gold action gradient. Single primary CTA per page (e.g. 'Analyze deck')."
    },
    "ctaKnowledge": {
      "value": "linear-gradient(135deg, #0E68AB 0%, #6A1B9A 100%)",
      "type": "gradient",
      "description": "Tier 2 — blue → purple knowledge gradient (e.g. 'Browse Library')."
    },
    "heroWubrg": {
      "value": "linear-gradient(90deg, #F8F6D8 0% 20%, #0E68AB 20% 40%, #150B00 40% 60%, #D3202A 60% 80%, #00733E 80% 100%)",
      "type": "gradient",
      "description": "Five-band WUBRG bar — section delimiter and hero text-fill."
    }
  },

  "typography": {
    "fontFamily": {
      "display": {
        "value": "\"Cinzel\", \"Playfair Display\", Georgia, serif",
        "type": "fontFamily",
        "description": "Headings H1–H4 only."
      },
      "body": {
        "value": "\"Inter\", system-ui, -apple-system, sans-serif",
        "type": "fontFamily",
        "description": "H5/H6, body, UI."
      },
      "mono": {
        "value": "\"JetBrains Mono\", ui-monospace, \"SF Mono\", Menlo, monospace",
        "type": "fontFamily",
        "description": "techTerm captions, tokens, math."
      }
    },
    "fontWeight": {
      "regular": { "value": 400, "type": "fontWeight" },
      "medium": { "value": 500, "type": "fontWeight" },
      "semibold": { "value": 600, "type": "fontWeight" },
      "bold": { "value": 700, "type": "fontWeight" }
    },
    "fontSize": {
      "h1": { "value": "3rem", "type": "dimension" },
      "h2": { "value": "2.5rem", "type": "dimension" },
      "h3": { "value": "2rem", "type": "dimension" },
      "h4": { "value": "1.5rem", "type": "dimension" },
      "h5": { "value": "1.25rem", "type": "dimension" },
      "h6": { "value": "1rem", "type": "dimension" },
      "body1": { "value": "1rem", "type": "dimension" },
      "body2": { "value": "0.875rem", "type": "dimension" },
      "tech": { "value": "0.75rem", "type": "dimension" }
    },
    "lineHeight": {
      "tight": { "value": 1.1, "type": "number" },
      "snug": { "value": 1.3, "type": "number" },
      "normal": { "value": 1.5, "type": "number" },
      "relaxed": { "value": 1.65, "type": "number" }
    },
    "letterSpacing": {
      "tight": { "value": "-0.005em", "type": "dimension" },
      "normal": { "value": "0", "type": "dimension" },
      "wide": { "value": "0.04em", "type": "dimension" },
      "wider": { "value": "0.14em", "type": "dimension" }
    }
  },

  "radius": {
    "sm": { "value": "6px", "type": "dimension" },
    "md": { "value": "8px", "type": "dimension" },
    "lg": { "value": "12px", "type": "dimension" },
    "xl": { "value": "16px", "type": "dimension" },
    "full": { "value": "9999px", "type": "dimension" }
  },

  "spacing": {
    "xs": { "value": "0.25rem", "type": "dimension" },
    "sm": { "value": "0.5rem", "type": "dimension" },
    "md": { "value": "1rem", "type": "dimension" },
    "lg": { "value": "1.5rem", "type": "dimension" },
    "xl": { "value": "2.5rem", "type": "dimension" },
    "2xl": { "value": "4rem", "type": "dimension" }
  },

  "shadow": {
    "card": {
      "value": "0 1px 2px rgba(20,11,0,0.04), 0 4px 16px rgba(20,11,0,0.04)",
      "type": "shadow"
    },
    "cardHover": {
      "value": "0 4px 12px rgba(20,11,0,0.08), 0 16px 40px rgba(20,11,0,0.10)",
      "type": "shadow"
    },
    "button": { "value": "0 2px 8px rgba(20,11,0,0.10)", "type": "shadow" },
    "buttonHover": { "value": "0 8px 24px rgba(20,11,0,0.18)", "type": "shadow" }
  },

  "motion": {
    "easing": {
      "standard": {
        "value": "cubic-bezier(0.4, 0, 0.2, 1)",
        "type": "cubicBezier",
        "description": "Material standard easing — default for all transitions."
      }
    },
    "duration": {
      "fast": { "value": "180ms", "type": "duration", "description": "Micro-states, focus rings." },
      "base": {
        "value": "320ms",
        "type": "duration",
        "description": "Hover transitions, default."
      },
      "slow": {
        "value": "600ms",
        "type": "duration",
        "description": "Mount animations, page-load reveals."
      }
    },
    "transform": {
      "cardLift": {
        "value": "translateY(-4px)",
        "type": "transform",
        "description": "Card hover state."
      },
      "buttonLift": {
        "value": "translateY(-2px)",
        "type": "transform",
        "description": "Button hover state."
      },
      "arrowNudge": {
        "value": "translateX(4px)",
        "type": "transform",
        "description": "CTA arrow hover state."
      }
    }
  },

  "zIndex": {
    "base": { "value": 1, "type": "number" },
    "raised": { "value": 10, "type": "number" },
    "sticky": { "value": 100, "type": "number" },
    "overlay": { "value": 1000, "type": "number" },
    "modal": { "value": 1100, "type": "number" },
    "toast": { "value": 1200, "type": "number" }
  }
}
